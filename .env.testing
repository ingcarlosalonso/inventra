SESSION_DRIVER=array
QUEUE_CONNECTION=sync
CACHE_STORE=array
BROADCAST_CONNECTION=null
MAIL_MAILER=array
FILESYSTEM_DISK=local

BCRYPT_ROUNDS=4

CENTRAL_DOMAIN="development.central.in-ventra.com"
